{
  "name": "cloud-code",
  "version": "1.0.0",
  "description": "GitHub Action that turns issues into autonomous Claude Code sessions",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "typecheck": "tsc --noEmit",
